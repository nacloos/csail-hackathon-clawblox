<mujoco model="panda cube scene">
  <compiler angle="radian" meshdir="../franka_emika_panda/assets" autolimits="true"/>

  <include file="../franka_emika_panda/panda.xml"/>

  <statistic center="0.35 0 0.35" extent="1.0"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.12 0.16 0.20 1"/>
    <global azimuth="135" elevation="-25"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.35 0.45 0.55" rgb2="0.02 0.03 0.04" width="512" height="3072"/>
    <texture type="2d" name="ground_grid" builtin="checker" mark="edge" rgb1="0.25 0.28 0.30" rgb2="0.16 0.18 0.20" markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="ground_grid" texture="ground_grid" texuniform="true" texrepeat="5 5" reflectance="0.18"/>
    <material name="table_mat" rgba="0.45 0.34 0.24 1"/>
    <material name="cube_mat" rgba="0.95 0.18 0.08 1"/>
  </asset>

  <worldbody>
    <light name="key" pos="0.2 -0.8 1.6" dir="-0.2 0.7 -1" directional="true"/>
    <light name="fill" pos="-0.6 0.4 1.2" dir="0.5 -0.2 -1" directional="true" diffuse="0.25 0.25 0.25"/>

    <geom name="floor" type="plane" size="2 2 0.05" material="ground_grid"/>

    <body name="table" pos="0.52 0 0.10">
      <geom name="table_top" type="box" size="0.36 0.32 0.10" material="table_mat" friction="0.8 0.1 0.1"/>
    </body>

    <body name="cube" pos="0.48 0 0.235">
      <freejoint name="cube_freejoint"/>
      <geom name="cube_geom" type="box" size="0.035 0.035 0.035" mass="0.08" material="cube_mat" friction="1.0 0.03 0.003"/>
    </body>

    <camera name="overview" pos="1.0 -1.0 0.75" xyaxes="0.707 0.707 0 -0.35 0.35 0.87"/>
  </worldbody>
</mujoco>
